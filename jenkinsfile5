pipeline {
    agent any

       environment {
        IMAGE_NAME = 'my-node-app'
        CONTAINER_NAME = 'node-app'
        PORT= 3003
        REPO_URL = 'https://github.com/malkiAbdelhamid/book-app.git'
        BRANCH = 'master' // or any branch you want to track
    }

    stages {

        stage('Clone Project') {
            steps {
             git branch: "${BRANCH}", url: "${REPO_URL}"
}
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                bat 'npm test'
            }
            post {
                success {
                    echo "All tests passed successfully!"
                }
                failure {
                    echo "Some tests failed. Please check logs."
                }
                
            }
        }

        stage('Build Docker Image') {
            steps {
                    // Build the Docker image
                    bat "docker build -t ${IMAGE_NAME} ."
                
            }
        }


     stage('Clean Old Container') {
        steps {
           bat "docker rm -f ${CONTAINER_NAME} || exit 0"
        }
}
        
        stage('Run New Container') {
            steps {
                script {
                    // Run the new container
                    bat "docker run -d  --name  ${CONTAINER_NAME}  -p ${PORT}:3000 ${IMAGE_NAME}"
                }
            }
        }


stage('Verify Deployment') {
   
    steps {
        script {
            echo "Verifying container is running..."

            def result = bat(
                script: "docker ps | findstr ${CONTAINER_NAME}",
                returnStatus: true
            )

            if (result == 0) {
                echo "Container is running successfully"
            } else {
                error "Container is NOT running"
            }
        }
    }
}
    
    }
    post {

        success {
            echo "Pipeline completed successfully!"
        }

        failure {
            echo "Pipeline failed!"
        }

       
        always {
            echo "Cleaning workspace..."
            cleanWs()
        }
    }
}